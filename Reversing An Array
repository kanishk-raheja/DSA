#include<iostream>
using namespace std;
int main()
{
    int n;
    cout<<"The number of terms is "<<n<<endl;
    cin>>n;
    int arr[n];
    for(int i=0;i<n;i++)
    {
        //Declaring an array
        cin>>arr[i];
        //Printing array
        cout<<arr[i]<<" ";

    }
  cout<<endl;
  cout<<"Reversed Array"<<endl;
    // Reversing Array
    for(int i=n-1;i>=0;i--)
    {
        cout<<arr[i]<<" ";
    }

}
