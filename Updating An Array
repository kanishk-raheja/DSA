#include<iostream>
using namespace std;
int main()
{
    int n;
    cout<<"The number of terms is "<<endl;
    cin>>n;
    int arr[n];
    for(int i=0;i<n;i++)
    {
        //Declaring an array
        cin>>arr[i];
        //Printing array
        cout<<arr[i]<<" ";

    }
    cout<<endl;
    // Reversing Array
    for(int i=n-1;i>=0;i--)
    {
        cout<<arr[i]<<" ";
    }
    cout<<endl;
    // Update elements in Array
    for(int i=0;i<n;i++)
    {
        arr[i]=2*arr[i];
        cout<<arr[i]<<" ";
    }

}
